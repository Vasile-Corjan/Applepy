<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Rename Files"
        Width="400" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Location of the drawings -->
        <TextBlock Text="Location of the drawings" Grid.Row="0" VerticalAlignment="Center" Margin="20,5,0,5" />
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="20,5,0,10">
            <TextBox x:Name="LocationTextBox" Width="260" />
            <Button Content="Browse" x:Name="Search_Directory" Width="60" Margin="5,0,0,0" Click="search_directory" />
        </StackPanel>

        <!-- Prefix of the drawing to search -->
        <TextBlock Text="Prefix of the drawing to search" Grid.Row="2" VerticalAlignment="Center" Margin="20,5,0,5" />
        <TextBox x:Name="PrefixTextBox" Grid.Row="3" Width="320" Margin="0,5,0,10"/>

        <!-- Replaces with -->
        <TextBlock Text="Replaces with" Grid.Row="4" VerticalAlignment="Center" Margin="20,5,0,5" />
        <TextBox x:Name="ReplaceTextBox" Grid.Row="5" Width="320" Margin="0,5,0,10"/>

        <!-- Set Values Button -->
        <StackPanel Orientation="Horizontal" Grid.Row="6" Margin="0,10,0,0" HorizontalAlignment="Center">
			<Button Content="Rename"  Width="100" Height="30" Margin="10,0,10,0" Click="rename_files"/>
            <Button Content="Cancel" Width="100" Height="30" Click="cancel_window"/>
        </StackPanel>
    </Grid>
</Window>
